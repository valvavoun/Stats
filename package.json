{
  "name": "mxgp-stats-v2",
  "version": "3.0.0",
  "description": "MXGP Stats — Scraper + Dashboard FIM Motocross World Championship",
  "scripts": {
    "scrape:ids":      "node scrape_ids.js",
    "scrape:ids:year": "node scrape_ids.js --year=2026",
    "scrape:data":     "node scrape_data.js --workers=3",
    "scrape:data:year":"node scrape_data.js --year=2026 --workers=2",
    "scrape:all":      "node scrape_ids.js && node scrape_data.js --workers=3",
    "serve":           "npx serve . --listen 3000"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  }
}
